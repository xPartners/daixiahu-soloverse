# ===== 应用基础配置 =====
# 应用名称
APP_NAME=ybA2A
# 应用版本
APP_VERSION=0.1.0
# 调试模式（生产环境请设为 False）
DEBUG=True
# API 路由前缀
API_V1_PREFIX=/api/v1

# ===== 数据库配置（PostgreSQL 异步驱动）=====
# 格式：postgresql+asyncpg://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/yba2a

# ===== Elasticsearch 配置 =====
# ES 服务地址
ES_URL=http://localhost:9200
# 政策文档索引名
ES_INDEX_POLICY=yba2a_policy
# 规则索引名
ES_INDEX_RULE=yba2a_rule

# ===== MinIO 对象存储配置 =====
# MinIO 服务地址（不含协议）
MINIO_ENDPOINT=localhost:9000
# MinIO 访问密钥
MINIO_ACCESS_KEY=minioadmin
# MinIO 访问秘钥
MINIO_SECRET_KEY=minioadmin
# 存储桶名称
MINIO_BUCKET=yba2a-files
# 是否启用 HTTPS（本地开发一般为 False）
MINIO_SECURE=False

# ===== 大模型（LLM）配置 =====
# 模型服务商（openai / 兼容 OpenAI 接口的服务商）
LLM_PROVIDER=openai
# API Key（请替换为真实密钥，切勿提交到代码仓库）
LLM_API_KEY=
# API 基础地址
LLM_BASE_URL=https://api.openai.com/v1
# 模型名称
LLM_MODEL=gpt-4o-mini
# 生成温度（0~2，越低越确定）
LLM_TEMPERATURE=0.2
# 单次最大生成 token 数
LLM_MAX_TOKENS=2048

# ===== 业务默认配置 =====
# 默认行政区划代码（示例：110000 表示北京）
DEFAULT_RULE_REGION=110000
